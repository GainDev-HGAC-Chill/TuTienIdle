function loadPlayers() { try { if (fs.existsSync(DATA_FILE)) return JSON.parse(fs.readFileSync(DATA_FILE, 'utf8')); } catch (err) { console.error('Lỗi đọc data:', err.message); } return {}; }
function savePlayers(players) { fs.writeFileSync(DATA_FILE, JSON.stringify(players, null, 2)); }
function systemName(system) { return { cultivation: 'Tu Luyện', body: 'Luyện Thể', soul: 'Luyện Hồn' }[system] || system; }
function createProgress(id) { return { id, rank: 1, phase: 1, exp: 0, maxExp: 100 }; }
function createDefaultTechniques() { return { equipped: { cultivation: 'tho_nap_quyet', body: 'man_nguu_luyen_the_quyet', soul: 'duong_than_quyet' }, learned: Object.fromEntries(TECHNIQUES.map(item => [item.id, createProgress(item.id)])) }; }
function createDefaultMartialSkills() { return { equipped: { active: 'co_ban_kiem_quyet' }, learned: Object.fromEntries(MARTIAL_SKILLS.map(item => [item.id, createProgress(item.id)])) }; }
function getRealmInfo(cultivation) { const index = Math.max(0, Math.min(REALMS.length - 1, Number(cultivation.realmIndex || 0))); const realm = REALMS[index]; const stage = Math.max(1, Math.min(realm.stages, Number(cultivation.stage || 1))); return { ...realm, realmIndex: index, stage, displayName: `${realm.name} ${stage}/${realm.stages}`, worldName: realm.world }; }
function getRealmNeed(cultivation) { const info = getRealmInfo(cultivation); return Math.floor(100 * Math.pow(1.55, info.realmIndex) * Math.pow(info.stage, 1.18)); }
function getMainRealmOrder(player) { return getRealmInfo(player.cultivation).order; }
function getMainAbsoluteRank(player) { const info = getRealmInfo(player.cultivation); return (info.order - 1) * 9 + info.stage; }
function getSubName(player, type) { const info = getRealmInfo({ realmIndex: Math.floor((Math.max(1, Number(player?.[type]?.rank || 1)) - 1) / 9), stage: ((Math.max(1, Number(player?.[type]?.rank || 1)) - 1) % 9) + 1 }); return `${info.name}${type === 'bodyCultivation' ? ' Thể' : ' Hồn'} ${info.stage}/${info.stages}`; }
function getUnlockedMaps(player) { const order = getMainRealmOrder(player); return MAPS.filter(map => map.requiredRealmOrder <= order); }
function getMapById(id) { return MAPS.find(map => map.id === id) || null; }
function getDefaultMapId() { return MAPS[0].id; }
function ensureCurrentMap(player) { const unlocked = getUnlockedMaps(player); if (!unlocked.some(map => map.id === player.currentZone)) player.currentZone = unlocked[0]?.id || getDefaultMapId(); return getMapById(player.currentZone) || unlocked[0] || MAPS[0]; }
function getAllItems() { return [...MATERIALS, ...HERBS, ...PILLS, ...ALCHEMY_BOOKS, ...CAULDRONS]; }
function addInventoryItem(player, id, amount = 1, extra = {}) { if (!player.inventory) player.inventory = []; const known = getAllItems().find(item => item.id === id); const name = extra.name || known?.name || id; const quality = extra.quality || ''; const item = player.inventory.find(x => x.id === id && (x.quality || '') === quality); if (item) item.amount = Number(item.amount || 0) + amount; else player.inventory.push({ id, name, amount, ...extra }); }
function removeInventoryItem(player, id, amount = 1, quality = null) { const item = (player.inventory || []).find(x => x.id === id && (quality === null || (x.quality || '') === quality)); if (!item || Number(item.amount || 0) < amount) return false; item.amount -= amount; if (item.amount <= 0) player.inventory = player.inventory.filter(x => x !== item); return true; }
function countItem(player, id) { return Number((player.inventory || []).find(x => x.id === id)?.amount || 0); }
function itemDisplayName(id) { return getAllItems().find(x => x.id === id)?.name || id || 'không rõ'; }
function actionLog(player, category, text, detail = '', meta = {}) { try { serverActionLog.writeActionLog({ username: player.username, category, text, detail, meta }); } catch (err) { console.warn('[ActionLog] Không thể ghi Nhật Ký Đạo Hành:', err.message); } }
function describeIngredients(ingredients = []) { return ingredients.map(item => `${itemDisplayName(item.id)} x${Number(item.amount || 1)}`).join(', ') || 'Không tiêu hao nguyên liệu.'; }
