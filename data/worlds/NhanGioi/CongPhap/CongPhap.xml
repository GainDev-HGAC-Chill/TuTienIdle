    <Affinity primaryElement="neutral" requireMatch="false"/>
    <Grades>
      <Grade id="pham"><Stats><Stat key="MAX_HP" value="80"/><Stat key="DEFENSE" value="20"/></Stats></Grade>
      <Grade id="hoang"><Stats><Stat key="MAX_HP" value="180"/><Stat key="DEFENSE" value="45"/><Stat key="POISON_RESIST" value="1"/><Stat key="BURN_RESIST" value="1"/></Stats></Grade>
      <Grade id="huyen"><Stats><Stat key="MAX_HP" value="360"/><Stat key="DEFENSE" value="90"/><Stat key="POISON_RESIST" value="3"/><Stat key="BURN_RESIST" value="3"/><Stat key="STUN_RESIST" value="1"/></Stats><Effects><Effect id="ngu_hanh_ho_the" chance="20" trigger="on_battle_start" status="SHIELD" maxHpScale="0.08"/></Effects></Grade>
      <Grade id="dia"><Stats><Stat key="MAX_HP" value="650"/><Stat key="DEFENSE" value="160"/><Stat key="POISON_RESIST" value="5"/><Stat key="BURN_RESIST" value="5"/><Stat key="FREEZE_RESIST" value="3"/><Stat key="STUN_RESIST" value="3"/></Stats><Effects><Effect id="ngu_hanh_ho_the" chance="100" trigger="on_battle_start" status="SHIELD" maxHpScale="0.12"/><Effect id="ngu_hanh_tinh_tam" chance="15" trigger="on_debuff_received" status="CLEAR_MIND"/></Effects></Grade>
    </Grades>
