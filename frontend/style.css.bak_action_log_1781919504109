:root {
  --bg: #080d16;
  --bg2: #101a33;
  --panel: #111a29;
  --panel2: #182337;
  --panel3: #202b3d;
  --border: #33445f;
  --text: #f8fafc;
  --muted: #c9d6ea;
  --gold: #f6c453;
  --gold2: #7a4f12;
  --green: #7ee6a0;
  --red: #f39a9a;
  --blue: #9ecbff;
}
* { box-sizing: border-box; }
html, body { margin: 0; min-height: 100%; }
body {
  background: radial-gradient(circle at top right, #18244b 0, #0c1426 38%, #070b12 100%);
  color: var(--text);
  font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 16px;
  line-height: 1.45;
}
button, input { font: inherit; }
button {
  cursor: pointer;
  border: 1px solid rgba(246, 196, 83, .38);
  border-radius: 13px;
  background: linear-gradient(180deg, #624214, #2d1f0c);
  color: #fff7df;
  padding: 10px 15px;
  font-weight: 800;
  text-shadow: 0 1px 0 rgba(0,0,0,.35);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.06), 0 8px 18px rgba(0,0,0,.18);
}
button:hover:not(:disabled) { border-color: var(--gold); filter: brightness(1.08); }
button:disabled { opacity: .65; cursor: default; }
button.success { background: linear-gradient(180deg, #80e8a2, #4aaa67); color: #06130b; border-color: #9cf1b8; }
button.danger { background: linear-gradient(180deg, #7a2f2f, #371111); border-color: rgba(243,154,154,.45); }
.hidden { display: none !important; }

.login-screen { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
.login-card {
  width: min(520px, 100%);
  padding: 36px;
  border-radius: 26px;
  background: rgba(17, 26, 41, .95);
  border: 1px solid var(--border);
  box-shadow: 0 30px 90px rgba(0,0,0,.45);
  text-align: center;
}
.sigil, .brand-icon {
  display: grid;
  place-items: center;
  width: 64px;
  height: 64px;
  margin: 0 auto 14px;
  border-radius: 18px;
  color: var(--gold);
  background: #2a2418;
  border: 1px solid rgba(246,196,83,.35);
  font-size: 34px;
}
.login-card h1 { margin: 8px 0; font-size: 42px; }
.login-card p, .login-card small { color: var(--muted); }
.login-row { display: flex; gap: 12px; margin: 26px 0 14px; }
.login-row input {
  flex: 1;
  min-width: 0;
  padding: 13px 15px;
  border-radius: 13px;
  background: #0b1220;
  border: 1px solid var(--border);
  color: var(--text);
}

.app { min-height: 100vh; display: grid; grid-template-columns: 272px minmax(0, 1fr); }
.sidebar {
  position: sticky;
  top: 0;
  height: 100vh;
  padding: 22px 16px;
  background: rgba(6, 11, 18, .96);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  z-index: 5;
}
.brand { display: flex; align-items: center; gap: 14px; margin-bottom: 24px; }
.brand-icon { width: 50px; height: 50px; margin: 0; font-size: 25px; flex: 0 0 auto; }
.brand h2 { margin: 0; font-size: 25px; }
.brand p, .profile span, .muted, .empty { color: var(--muted); }
.profile {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px;
  border-radius: 17px;
  background: rgba(24,35,55,.88);
  border: 1px solid var(--border);
  margin-bottom: 18px;
}
.avatar { width: 42px; height: 42px; display: grid; place-items: center; border-radius: 50%; background: var(--panel3); color: var(--gold); }
.profile span { display: block; font-size: 13px; margin-top: 3px; }
.nav { display: grid; gap: 8px; }
.nav-btn, .ghost-btn {
  width: 100%;
  text-align: left;
  background: transparent;
  border-color: transparent;
  color: var(--text);
  box-shadow: none;
}
.nav-btn.active { color: #fff7df; border-color: rgba(246,196,83,.45); background: rgba(246,196,83,.10); }
.ghost-btn { margin-top: 18px; text-align: center; border-color: var(--border); color: var(--muted); }

.content {
  min-width: 0;
  padding: 30px;
  overflow-x: hidden;
}
.topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20px;
  margin-bottom: 22px;
}
.topbar h1 { margin: 0 0 6px; font-size: clamp(34px, 4vw, 52px); line-height: 1; letter-spacing: -.04em; }
.topbar p { margin: 0; color: var(--muted); }
.top-actions { display: flex; gap: 10px; flex-wrap: wrap; justify-content: flex-end; }
.tab-page { display: none; }
.tab-page.active { display: block; }
.grid { display: grid; gap: 20px; }
.grid.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.wide { grid-column: 1 / -1; }
.panel {
  background: rgba(17, 26, 41, .92);
  border: 1px solid var(--border);
  border-radius: 22px;
  padding: 22px;
  box-shadow: 0 16px 45px rgba(0,0,0,.20);
  min-width: 0;
}
.panel h3 { margin: 0 0 15px; color: #fff7df; font-size: 20px; }
.panel h2 { margin: 8px 0 14px; font-size: 28px; }
.panel-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
.panel-head h3 { margin: 0; }
.panel-head span { color: var(--gold); font-weight: 800; }
.strong-line { font-weight: 800; color: #fff7df; }
.stat-row { display: flex; justify-content: space-between; gap: 16px; padding: 11px 0; border-bottom: 1px dashed rgba(148,163,184,.22); }
.stat-row:last-child { border-bottom: 0; }
.stat-row b { color: #fff7df; }
.card-list, .inventory-grid, .recipe-grid { display: grid; gap: 12px; }
.card-list.compact, .inventory-grid, .recipe-grid { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
.mini-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 16px;
  border-radius: 16px;
  background: var(--panel2);
  border: 1px solid rgba(148,163,184,.25);
}
.mini-card p { margin: 6px 0 0; color: var(--muted); }
.mini-card span { color: var(--gold); white-space: nowrap; font-size: 13px; }
.realm-box span { color: var(--gold); font-weight: 800; }

.progress-panels.clean { grid-template-columns: repeat(3, minmax(220px, 1fr)); }
.progress-panels { display: grid; gap: 14px; margin: 16px 0; }
.progress-panel {
  display: block;
  text-align: left;
  background: var(--panel2);
  border: 1px solid rgba(148,163,184,.25);
  border-radius: 17px;
  color: var(--text);
  padding: 16px;
  box-shadow: none;
}
.progress-panel.active { border-color: var(--gold); background: linear-gradient(145deg, rgba(122,79,18,.72), rgba(54,37,17,.86)); }
.progress-head, .progress-foot { display: flex; justify-content: space-between; gap: 12px; align-items: center; }
.progress-head span { color: var(--blue); font-size: 13px; }
.progress-head b { padding: 4px 8px; border-radius: 999px; background: rgba(148,163,184,.18); color: var(--muted); font-size: 12px; }
.progress-panel.active .progress-head b { background: var(--green); color: #06200d; }
.progress-panel h4 { margin: 12px 0 6px; font-size: 20px; }
.progress-panel p { color: var(--muted); min-height: 22px; margin: 0 0 12px; }
.progress-foot { margin-top: 8px; }
.progress-foot span { color: var(--gold); font-weight: 800; }
.button-row { display: flex; gap: 10px; flex-wrap: wrap; }

.bar { height: 12px; border-radius: 999px; background: rgba(148,163,184,.23); overflow: hidden; }
.bar i { display: block; height: 100%; width: 0; border-radius: inherit; background: var(--green); transition: width .25s ease; }
.bar.hp i { background: var(--red); }
.bar.enemy i { background: #ffcc7a; }
.bar-line { margin: 17px 0; text-align: left; }
.bar-line > span { color: var(--muted); }
.bar-line > b { float: right; }
.bar-line .bar { clear: both; margin-top: 8px; }
.combat-card { min-height: 430px; text-align: center; }
.monster-icon { width: 88px; height: 88px; display: grid; place-items: center; margin: 18px auto; border-radius: 30px; background: #2a2418; color: var(--gold); border: 1px solid rgba(246,196,83,.35); font-size: 46px; }
.map-list { display: grid; gap: 13px; max-height: 560px; overflow: auto; padding-right: 4px; }
.map-group { border: 1px solid rgba(148,163,184,.22); border-radius: 17px; overflow: hidden; background: rgba(255,255,255,.02); }
.map-group-head { width: 100%; display: flex; justify-content: space-between; border: 0; border-radius: 0; background: var(--panel2); color: var(--text); box-shadow: none; }
.map-group-head span { color: var(--gold); }
.map-group-body { display: grid; gap: 10px; padding: 12px; }
.map-card { display: block; width: 100%; text-align: left; background: var(--panel); border-color: rgba(148,163,184,.24); color: var(--text); box-shadow: none; }
.map-card.active { border-color: var(--gold); background: rgba(246,196,83,.12); }
.map-card span { display: block; color: var(--blue); margin-top: 5px; }
.map-card p { margin: 8px 0 0; color: var(--muted); }
.log-list { display: grid; gap: 8px; max-height: 320px; overflow: auto; }
.log-list p { margin: 0; padding: 11px 12px; border-radius: 11px; background: rgba(255,255,255,.05); color: #d8e6ff; }

.skill-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; }
.practice-card {
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-height: 250px;
  padding: 18px;
  border-radius: 18px;
  background: var(--panel2);
  border: 1px solid rgba(148,163,184,.25);
}
.practice-card.equipped { border-color: var(--gold); background: linear-gradient(145deg, rgba(80,50,15,.58), rgba(22,31,46,.90)); }
.practice-top, .practice-bottom { display: flex; justify-content: space-between; gap: 12px; align-items: center; }
.practice-top h4 { margin: 0; font-size: 19px; }
.practice-top span, .practice-system { color: var(--gold); }
.practice-card p { color: var(--muted); margin: 0; }
.chip-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: auto; }
.chip { display: inline-flex; gap: 5px; padding: 7px 10px; border-radius: 999px; background: rgba(148,163,184,.16); color: #dbe8ff; font-size: 13px; }
.chip b { color: var(--gold); }
.practice-bottom strong { color: var(--green); }
.garden-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; }
.garden-plot { padding: 16px; border-radius: 16px; background: var(--panel2); border: 1px solid rgba(148,163,184,.25); }
.garden-plot p { color: var(--muted); margin: 8px 0 0; }
.inventory-list h4 { margin: 22px 0 10px; color: #fff7df; }

.encounter-popup { position: fixed; inset: 0; display: grid; place-items: center; background: rgba(0,0,0,.58); z-index: 20; padding: 24px; }
.encounter-card { width: min(720px, 100%); padding: 28px; border-radius: 24px; background: #121a28; border: 1px solid var(--gold); box-shadow: 0 30px 100px rgba(0,0,0,.55); }
.encounter-card h2 { margin-top: 0; color: #fff7df; }
.encounter-card small { display: block; margin-top: 14px; color: var(--muted); }

@media (max-width: 1100px) {
  .grid.two, .progress-panels.clean { grid-template-columns: 1fr; }
}
@media (max-width: 860px) {
  .app { grid-template-columns: 1fr; }
  .sidebar { position: static; height: auto; }
  .content { padding: 20px; }
  .topbar { flex-direction: column; }
  .login-row { flex-direction: column; }
}

/* =============================== */
/* Feature polish: Thọ Nguyên / Đan / Dược Viên */
/* =============================== */
.lifespan-panel h2 { color: #ffd76a; }
.recipe-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 14px; }
.recipe-card, .pill-card, .garden-plot {
  background: linear-gradient(145deg, rgba(23,34,52,.96), rgba(14,23,36,.96));
  border: 1px solid rgba(103,133,174,.34);
  border-radius: 16px;
  padding: 16px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.035);
}
.recipe-card:hover, .pill-card:hover, .garden-plot:hover { border-color: rgba(247,190,76,.65); }
.recipe-head, .pill-card { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; }
.recipe-head h4, .pill-card h4, .garden-plot h4 { margin: 0 0 8px; color: #fff6d8; }
.recipe-head span { color: #ffd76a; font-weight: 800; white-space: nowrap; }
.recipe-card p, .pill-card p, .garden-plot p { margin: 8px 0; color: #cfe2ff; line-height: 1.45; }
.recipe-card b, .pill-card b { color: #ffd76a; }
.pill-card button, .recipe-card button, .garden-plot button, .garden-plot select {
  border-radius: 12px;
}
.pill-card button { min-width: 78px; }
.garden-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; }
.garden-plot.ready { border-color: rgba(116,235,154,.75); }
.garden-plot.growing { border-color: rgba(247,190,76,.55); }
.garden-plot select {
  width: 100%;
  margin: 10px 0;
  padding: 10px 12px;
  background: rgba(8,14,24,.92);
  color: #eaf3ff;
  border: 1px solid rgba(103,133,174,.45);
}
.garden-plot button:disabled { opacity: .55; cursor: not-allowed; }
.mini-actions { justify-content: flex-end; margin: 0; }
button.ghost, .ghost {
  background: rgba(20,31,48,.95) !important;
  border-color: rgba(103,133,174,.55) !important;
  color: #dceaff !important;
}
.practice-bottom { gap: 10px; }
.practice-bottom strong { color: #74eb9a; }
.chip-row { display:flex; flex-wrap:wrap; gap:8px; }
.chip { display:inline-flex; gap:5px; align-items:center; padding:6px 9px; border-radius:999px; background:rgba(255,255,255,.08); color:#dceaff; font-size:13px; }
.chip b { color:#ffd76a; }
.top-actions button, button {
  background: linear-gradient(180deg, #6b4813, #3d290c);
  border: 1px solid #9b741d;
  color: #fff6d8;
  font-weight: 800;
  padding: 10px 15px;
  border-radius: 12px;
  cursor: pointer;
}
.top-actions button:hover, button:hover { filter: brightness(1.12); }
button.success, .success { background: linear-gradient(180deg, #75eaa0, #3ba86b) !important; border-color:#92f4b3 !important; color:#07140d !important; }
@media (max-width: 1100px) {
  .recipe-grid, .garden-grid { grid-template-columns: 1fr; }
  .pill-card, .recipe-head { flex-direction: column; }
}


/* =============================== */
/* Nhật Ký Đạo Hành */
/* =============================== */

.activity-panel .panel-head span { color: #ffd76a; font-weight: 800; }

.activity-log-list {
 display: grid;
 gap: 10px;
 max-height: 360px;
 overflow: auto;
 padding-right: 4px;
}

.activity-log-item {
 padding: 12px 14px;
 border-radius: 14px;
 background: linear-gradient(145deg, rgba(23,34,52,.96), rgba(10,18,30,.96));
 border: 1px solid rgba(103,133,174,.34);
 box-shadow: inset 0 1px 0 rgba(255,255,255,.035);
}

.activity-log-item > div {
 display: flex;
 justify-content: space-between;
 gap: 12px;
 align-items: center;
 margin-bottom: 6px;
}

.activity-log-item b { color: #ffd76a; }
.activity-log-item span { color: #8fb9ff; font-size: 12px; white-space: nowrap; }
.activity-log-item strong { color: #fff6d8; font-weight: 800; }
.activity-log-item p { margin: 7px 0 0; color: #cfe2ff; line-height: 1.45; }

.activity-alchemy { border-color: rgba(204,154,255,.55); }
.activity-fortune { border-color: rgba(255,215,106,.7); }
.activity-item { border-color: rgba(116,235,154,.55); }
.activity-cave { border-color: rgba(93,214,255,.55); }
.activity-cultivation { border-color: rgba(255,180,92,.55); }
.activity-skill { border-color: rgba(255,120,120,.55); }
